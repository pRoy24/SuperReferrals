# Production: live providers. Prefer private/paid RPC providers for reliability.
APP_BASE_URL=https://your-domain.example
DEPLOYMENT_ENV=production
NEXT_PUBLIC_DEPLOYMENT_ENV=production
SUPERREFERRALS_DATA_DIR=/tmp/superreferrals
ALLOW_MOCK_RENDER_PAYMENT=false

SUPERREFERRALS_MOCKS=false
SAMSAR_MOCKS=false
SAMSAR_API_KEY=replace_with_samsar_api_key
SAMSAR_API_URL=https://api.samsar.one
SAMSAR_WEBHOOK_SECRET=replace_with_samsar_webhook_secret

UNISWAP_MOCKS=false
UNISWAP_API_KEY=replace_with_uniswap_api_key
UNISWAP_BASE_URL=https://trade-api.gateway.uniswap.org/v1

# Production wallet/payment/contract transactions use Ethereum mainnet by default.
# To deploy a Base instance, set TRANSACTION_NETWORK=base and TRANSACTION_CHAIN_ID=8453.
TRANSACTION_NETWORK=mainnet
TRANSACTION_CHAIN_ID=1
TRANSACTION_RPC_URL=https://eth.llamarpc.com
TRANSACTION_EXPLORER_URL=https://etherscan.io
NEXT_PUBLIC_TRANSACTION_NETWORK=mainnet
NEXT_PUBLIC_TRANSACTION_CHAIN_ID=1
NEXT_PUBLIC_TRANSACTION_RPC_URL=https://eth.llamarpc.com
NEXT_PUBLIC_TRANSACTION_EXPLORER_URL=https://etherscan.io
TRANSACTION_PRIVATE_KEY=replace_with_transaction_signer_private_key

KEEPERHUB_MOCKS=false
KEEPERHUB_API_KEY=replace_with_keeperhub_api_key
KEEPERHUB_BASE_URL=https://app.keeperhub.com/api
KEEPERHUB_PAYMENT_NETWORK=ethereum
KEEPERHUB_REFUND_NETWORK=ethereum
KEEPERHUB_REFUND_TOKEN_ADDRESS=
KEEPERHUB_PLATFORM_WALLET_ADDRESS=replace_with_keeperhub_wallet
KEEPERHUB_PAYMENT_WORKFLOW_ID=replace_with_keeperhub_ethereum_workflow_id
KEEPERHUB_PAYMENT_WORKFLOW_ID_ETHEREUM=replace_with_keeperhub_ethereum_workflow_id
KEEPERHUB_PAYMENT_WORKFLOW_ID_BASE=replace_with_keeperhub_base_workflow_id
KEEPERHUB_ETH_USD_PRICE_HINT=3000

# 0G mainnet defaults from 0G docs.
ZERO_G_MOCKS=false
AGENT_REGISTRY_MOCKS=false
USER_REGISTRY_MOCKS=false
OG_NETWORK=mainnet
OG_CHAIN_ID=16661
OG_RPC_URL=https://evmrpc.0g.ai
OG_BLOCK_EXPLORER_URL=https://chainscan.0g.ai
OG_STORAGE_MODE=turbo
OG_STORAGE_INDEXER_RPC=https://indexer-storage-turbo.0g.ai
OG_PRIVATE_KEY=replace_with_0g_storage_signer_private_key
USER_REGISTRY_CONTRACT_ADDRESS=replace_with_deployed_user_registry
USER_REGISTRY_PRIVATE_KEY=replace_with_user_registry_signer_private_key
USER_REGISTRY_CHAIN_ID=16661
AGENT_REGISTRY_CONTRACT_ADDRESS=replace_with_deployed_agent_registry
AGENT_REGISTRY_PRIVATE_KEY=replace_with_agent_registry_signer_private_key
AGENT_REGISTRY_CHAIN_ID=16661
AGENT_REGISTRY_RPC_URL=https://evmrpc.0g.ai
OG_DA_URL=replace_with_0g_da_publish_endpoint
OG_DA_API_KEY=
OG_SERVICE_MARKETPLACE_MOCKS=false
OG_SERVICE_MARKETPLACE_URL=replace_with_0g_service_marketplace_endpoint
OG_SERVICE_MARKETPLACE_API_KEY=

INFT_MOCKS=false
INFT_CHAIN_ID=16661
INFT_RPC_URL=https://evmrpc.0g.ai
INFT_CONTRACT_ADDRESS=replace_with_deployed_inft_contract
INFT_MINTER_PRIVATE_KEY=replace_with_inft_minter_private_key

OG_COMPUTE_MOCKS=false
OG_COMPUTE_URL=replace_with_0g_compute_endpoint
OG_COMPUTE_API_KEY=

# AXL is still local to the AXL node process.
AXL_MOCKS=false
AXL_BASE_URL=http://localhost:9002

# ENS resolution starts from Ethereum mainnet for production names.
ENS_CHAIN_ID=1
ENS_RPC_URL=https://eth.llamarpc.com
