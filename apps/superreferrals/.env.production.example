# SuperReferrals production runtime env
APP_BASE_URL=https://super-referrals.vercel.app
DEPLOYMENT_ENV=production
NEXT_PUBLIC_DEPLOYMENT_ENV=production

SUPERREFERRALS_SESSION_SECRET=
SUPERREFERRALS_MOCKS=false

# Samsar platform APP_SECRET.
# Used server-side to create/authenticate generated Samsar APP_KEY credentials
# for connected storefront accounts, and to encrypt stored APP_KEYs.
# Get it from the Samsar platform credentials for this environment.
# The app can run without it, but live storefront APP_KEY provisioning will be disabled.
SAMSAR_APP_SECRET=

# Payment chain
TRANSACTION_NETWORK=ethereum
TRANSACTION_CHAIN_ID=1
TRANSACTION_RPC_URL=https://ethereum-rpc.publicnode.com
TRANSACTION_EXPLORER_URL=https://etherscan.io
NEXT_PUBLIC_TRANSACTION_NETWORK=ethereum
NEXT_PUBLIC_TRANSACTION_CHAIN_ID=1
NEXT_PUBLIC_TRANSACTION_RPC_URL=https://ethereum-rpc.publicnode.com
NEXT_PUBLIC_TRANSACTION_EXPLORER_URL=https://etherscan.io

# Settlement
KEEPERHUB_API_KEY=
KEEPERHUB_WALLET_ADDRESS=

# 0G
OG_NETWORK=mainnet
OG_CHAIN_ID=16661
OG_RPC_URL=https://evmrpc.0g.ai
OG_BLOCK_EXPLORER_URL=https://chainscan.0g.ai
OG_STORAGE_INDEXER_RPC=https://indexer-storage-turbo.0g.ai
OG_PRIVATE_KEY=
OG_DA_URL=

# Contracts and agent services
USER_REGISTRY_CONTRACT_ADDRESS=
AGENT_REGISTRY_CONTRACT_ADDRESS=
OG_SERVICE_MARKETPLACE_URL=
INFT_CONTRACT_ADDRESS=
AXL_BASE_URL=
ENS_CHAIN_ID=1
ENS_RPC_URL=https://ethereum-rpc.publicnode.com

# Admin
ADMIN_SECRET=
