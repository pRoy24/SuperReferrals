    "react-dom": "latest",
    "samsar-js": "^0.48.24",
    "viem": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "hardhat": "2.26.3",
    "ts-node": "^10.9.2",
    "typescript": "latest"
