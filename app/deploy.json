{
  "vercel": {
    "defaultScope": "proy24s-projects",
    "defaultProject": "super-referrals",
    "blob": {
      "enabled": false,
      "storeName": "superreferrals-private",
      "access": "private",
      "region": "iad1"
    },
    "redis": {
      "integration": "upstash/upstash-kv",
      "resourceName": "superreferrals-redis",
      "plan": "free",
      "primaryRegion": "iad1",
      "eviction": false,
      "prodPack": false,
      "autoUpgrade": false
    }
  },
  "targets": {
    "staging": {
      "envFile": ".env.staging",
      "environment": "preview",
      "branch": "develop"
    },
    "production": {
      "envFile": ".env.production",
      "environment": "production",
      "branch": "",
      "redisFromTarget": "staging"
    }
  },
  "zeroG": {
    "required": [
      "OG_CHAIN_ID",
      "OG_RPC_URL",
      "OG_STORAGE_INDEXER_RPC"
    ],
    "recommended": [
      "OG_STORAGE_GATEWAY_URL",
      "INFT_CHAIN_ID",
      "INFT_RPC_URL",
      "INFT_CONTRACT_ADDRESS",
      "USER_REGISTRY_CONTRACT_ADDRESS",
      "AGENT_REGISTRY_CONTRACT_ADDRESS",
      "OG_PRIVATE_KEY",
      "OG_DA_URL",
      "KEEPERHUB_API_KEY",
      "KEEPERHUB_WALLET_ADDRESS",
      "SAMSAR_APP_SECRET",
      "ADMIN_SECRET",
      "SUPERREFERRALS_SESSION_SECRET"
    ]
  }
}
