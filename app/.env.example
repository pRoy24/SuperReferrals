# SuperReferrals local runtime env
APP_BASE_URL=http://localhost:3000
DEPLOYMENT_ENV=local
NEXT_PUBLIC_DEPLOYMENT_ENV=local

SUPERREFERRALS_SESSION_SECRET=
SUPERREFERRALS_MOCKS=true

# Samsar platform APP_SECRET.
# Used server-side to create/authenticate generated Samsar APP_KEY credentials
# for connected storefront accounts, and to encrypt stored APP_KEYs.
# Get it from the Samsar platform credentials for this environment.
# The app can run without it, but live storefront APP_KEY provisioning will be disabled.
SAMSAR_APP_SECRET=

# Payment chain
TRANSACTION_NETWORK=sepolia
TRANSACTION_CHAIN_ID=11155111
TRANSACTION_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
TRANSACTION_EXPLORER_URL=https://sepolia.etherscan.io
NEXT_PUBLIC_TRANSACTION_NETWORK=sepolia
NEXT_PUBLIC_TRANSACTION_CHAIN_ID=11155111
NEXT_PUBLIC_TRANSACTION_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_TRANSACTION_EXPLORER_URL=https://sepolia.etherscan.io

# Settlement
KEEPERHUB_API_KEY=
KEEPERHUB_WALLET_ADDRESS=

# 0G
OG_NETWORK=galileo
OG_CHAIN_ID=16602
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_BLOCK_EXPLORER_URL=https://chainscan-galileo.0g.ai
OG_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
OG_PRIVATE_KEY=
OG_DA_URL=

# Contracts and agent services
USER_REGISTRY_CONTRACT_ADDRESS=
AGENT_REGISTRY_CONTRACT_ADDRESS=
OG_SERVICE_MARKETPLACE_URL=
INFT_CONTRACT_ADDRESS=
AXL_BASE_URL=http://localhost:9002
ENS_CHAIN_ID=11155111
ENS_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Admin
ADMIN_SECRET=
