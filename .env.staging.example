# Staging: live Samsar, KeeperHub Sepolia payment, and live 0G user records; mint/AXL remain mocked by default.
# Wallet/payment adapters target Sepolia. User profile records target 0G Galileo.
APP_BASE_URL=http://localhost:3000
DEPLOYMENT_ENV=staging
NEXT_PUBLIC_DEPLOYMENT_ENV=staging
SUPERREFERRALS_DATA_DIR=/tmp/superreferrals
ALLOW_MOCK_RENDER_PAYMENT=false

SUPERREFERRALS_MOCKS=true
SAMSAR_MOCKS=false
SAMSAR_API_KEY=replace_with_samsar_api_key
SAMSAR_API_URL=https://api.samsar.one

UNISWAP_MOCKS=true
KEEPERHUB_MOCKS=false
KEEPERHUB_API_KEY=replace_with_keeperhub_api_key
ZERO_G_MOCKS=false
AGENT_REGISTRY_MOCKS=true
USER_REGISTRY_MOCKS=false
OG_SERVICE_MARKETPLACE_MOCKS=true
INFT_MOCKS=true
OG_COMPUTE_MOCKS=true
AXL_MOCKS=true

# Staging wallet/payment/contract transactions use Ethereum Sepolia.
TRANSACTION_NETWORK=sepolia
TRANSACTION_CHAIN_ID=11155111
TRANSACTION_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
TRANSACTION_EXPLORER_URL=https://sepolia.etherscan.io
NEXT_PUBLIC_TRANSACTION_NETWORK=sepolia
NEXT_PUBLIC_TRANSACTION_CHAIN_ID=11155111
NEXT_PUBLIC_TRANSACTION_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_TRANSACTION_EXPLORER_URL=https://sepolia.etherscan.io
TRANSACTION_PRIVATE_KEY=

KEEPERHUB_PAYMENT_NETWORK=sepolia
KEEPERHUB_REFUND_NETWORK=sepolia
KEEPERHUB_REFUND_TOKEN_ADDRESS=
KEEPERHUB_PLATFORM_WALLET_ADDRESS=replace_with_keeperhub_wallet
KEEPERHUB_PAYMENT_WORKFLOW_ID=replace_with_keeperhub_sepolia_workflow_id
KEEPERHUB_PAYMENT_WORKFLOW_ID_SEPOLIA=replace_with_keeperhub_sepolia_workflow_id

# 0G Galileo testnet defaults from 0G docs.
OG_NETWORK=galileo
OG_CHAIN_ID=16602
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_BLOCK_EXPLORER_URL=https://chainscan-galileo.0g.ai
OG_STORAGE_MODE=turbo
OG_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
OG_PRIVATE_KEY=replace_with_0g_storage_signer_private_key
USER_REGISTRY_CONTRACT_ADDRESS=replace_with_deployed_user_registry
USER_REGISTRY_PRIVATE_KEY=replace_with_user_registry_signer_private_key
USER_REGISTRY_CHAIN_ID=16602
AGENT_REGISTRY_CONTRACT_ADDRESS=
AGENT_REGISTRY_PRIVATE_KEY=
AGENT_REGISTRY_CHAIN_ID=16602
AGENT_REGISTRY_RPC_URL=https://evmrpc-testnet.0g.ai
OG_DA_URL=
OG_DA_API_KEY=
OG_SERVICE_MARKETPLACE_URL=
OG_SERVICE_MARKETPLACE_API_KEY=

INFT_CHAIN_ID=16602
INFT_RPC_URL=https://evmrpc-testnet.0g.ai
INFT_CONTRACT_ADDRESS=
INFT_MINTER_PRIVATE_KEY=

# AXL is a local node API when enabled.
AXL_BASE_URL=http://localhost:9002

# Staging ENS tests should resolve against Sepolia.
ENS_CHAIN_ID=11155111
ENS_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
