# SuperReferrals staging runtime env
APP_BASE_URL=https://super-referrals-git-develop-proy24s-projects.vercel.app
DEPLOYMENT_ENV=staging
NEXT_PUBLIC_DEPLOYMENT_ENV=staging
SUPERREFERRALS_SESSION_SECRET=replace_with_random_session_secret
SUPERREFERRALS_MOCKS=false

# Optional local Redis only. Deploy setup injects KV on Vercel.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Samsar storefront-owner auth
SAMSAR_APP_SECRET=replace_with_64_plus_character_samsar_app_secret
SAMSAR_WEBHOOK_SECRET=

# Wallet payment network
TRANSACTION_NETWORK=sepolia
TRANSACTION_CHAIN_ID=11155111
TRANSACTION_RPC_URL=replace_with_sepolia_rpc_url
TRANSACTION_EXPLORER_URL=https://sepolia.etherscan.io
NEXT_PUBLIC_TRANSACTION_NETWORK=sepolia
NEXT_PUBLIC_TRANSACTION_CHAIN_ID=11155111
NEXT_PUBLIC_TRANSACTION_RPC_URL=replace_with_sepolia_rpc_url
NEXT_PUBLIC_TRANSACTION_EXPLORER_URL=https://sepolia.etherscan.io
UNISWAP_API_KEY=

# KeeperHub settlement
KEEPERHUB_API_KEY=replace_with_keeperhub_api_key
KEEPERHUB_WALLET_ADDRESS=replace_with_keeperhub_wallet_address
KEEPERHUB_PAYMENT_WORKFLOW_ID_SEPOLIA=replace_with_keeperhub_sepolia_workflow_id

# 0G chain, storage, DA, and registries
OG_NETWORK=galileo
OG_CHAIN_ID=16602
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_BLOCK_EXPLORER_URL=https://chainscan-galileo.0g.ai
OG_STORAGE_INDEXER_RPC=replace_with_0g_storage_indexer_rpc
OG_PRIVATE_KEY=replace_with_0g_private_key
OG_DA_URL=replace_with_0g_da_url
USER_REGISTRY_CONTRACT_ADDRESS=replace_with_user_registry_contract
AGENT_REGISTRY_CONTRACT_ADDRESS=replace_with_agent_registry_contract
OG_SERVICE_MARKETPLACE_URL=replace_with_0g_service_marketplace_url
INFT_CONTRACT_ADDRESS=replace_with_inft_contract

# Integrations
AXL_BASE_URL=replace_with_axl_base_url
ENS_CHAIN_ID=11155111
ENS_RPC_URL=replace_with_ens_rpc_url
