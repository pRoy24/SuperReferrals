# Core app
APP_BASE_URL=http://localhost:3000
SUPERREFERRALS_MOCKS=false
SUPERREFERRALS_DATA_DIR=.superreferrals
SUPERREFERRALS_SESSION_SECRET=
ALLOW_MOCK_RENDER_PAYMENT=false

# Samsar public API
SAMSAR_MOCKS=false
SAMSAR_API_KEY=
SAMSAR_API_URL=https://api.samsar.one
SAMSAR_WEBHOOK_SECRET=

# Uniswap Trading API
UNISWAP_MOCKS=false
UNISWAP_API_KEY=
UNISWAP_BASE_URL=https://trade-api.gateway.uniswap.org/v1

# Wallet and transaction network. Non-production defaults to Sepolia.
TRANSACTION_NETWORK=sepolia
TRANSACTION_CHAIN_ID=11155111
TRANSACTION_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
TRANSACTION_EXPLORER_URL=https://sepolia.etherscan.io
NEXT_PUBLIC_TRANSACTION_NETWORK=sepolia
NEXT_PUBLIC_TRANSACTION_CHAIN_ID=11155111
NEXT_PUBLIC_TRANSACTION_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_TRANSACTION_EXPLORER_URL=https://sepolia.etherscan.io

# KeeperHub direct execution
KEEPERHUB_MOCKS=false
KEEPERHUB_API_KEY=
KEEPERHUB_BASE_URL=https://app.keeperhub.com/api
KEEPERHUB_PAYMENT_NETWORK=sepolia
KEEPERHUB_REFUND_NETWORK=sepolia
# Use the enabled KeeperHub payment workflow id after configuring the builder actions.
KEEPERHUB_WALLET_ADDRESS=
KEEPERHUB_PAYMENT_WORKFLOW_ID=
KEEPERHUB_PAYMENT_WORKFLOW_ID_SEPOLIA=
KEEPERHUB_PAYMENT_WORKFLOW_ID_ETHEREUM=
KEEPERHUB_PAYMENT_WORKFLOW_ID_BASE=
KEEPERHUB_ETH_USD_PRICE_HINT=3000

